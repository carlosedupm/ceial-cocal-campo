{
  "name": "Cocal Campo",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "devcontainer",
  "workspaceFolder": "/workspaces/cocal-campo",
  "mounts": [
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly"
  ],
  "remoteEnv": {
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "GITHUB_REPO": "${localEnv:GITHUB_REPO}",
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  
  "forwardPorts": [5173, 8080],
  "portsAttributes": {
    "5173": { "label": "PWA Frontend", "onAutoForward": "openBrowser" },
    "8080": { "label": "API Go" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "golang.go",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "go.toolsManagement.autoUpdate": false
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postAttachCommand": "echo \"▶ Run and Debug → selecione 'Cocal Campo (API + PWA)' → F5 para iniciar\"",
  "remoteUser": "node"
}
